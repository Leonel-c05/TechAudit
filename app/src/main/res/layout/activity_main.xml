<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TechAudit"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="20dp"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- LISTA DE LABORATORIOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLaboratorios"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        tools:listitem="@layout/item_laboratorio"/>

    <!-- LISTA DE EQUIPOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAuditoria"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/rvLaboratorios"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_audit"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Agregar Equipo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>